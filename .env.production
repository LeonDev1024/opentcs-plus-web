# 页面标题
VITE_APP_TITLE = OPENTCS调度管理平台
VITE_APP_LOGO_TITLE = OPENTCS调度管理平台
VITE_APP_LOGO_TITLE_MAIN = OPENTCSPLUS
VITE_APP_LOGO_TITLE_SUB = 调度管理平台
VITE_APP_ENV=production
VITE_APP_PORT=5173
VITE_APP_CONTEXT_PATH=/

# Backend API (served via reverse proxy or same origin)
VITE_APP_BASE_API=/prod-api
VITE_APP_BASE_URL=/

# Security/crypto — 须与后端 application.yml 中 api-decrypt 密钥一致；关闭加密时后端也需 api-decrypt.enabled: false
VITE_APP_ENCRYPT=true
VITE_APP_RSA_PUBLIC_KEY=MFwwDQYJKoZIhvcNAQEBBQADSwAwSAJBAKoR8mX0rGKLqzcWmOzbfj64K8ZIgOdHnzkXSOVOZbFu/TJhZ7rFAN+eaGkl3C4buccQd/EjEsj9ir7ijT7h96MCAwEAAQ==
VITE_APP_RSA_PRIVATE_

# OAuth / client id — 须与库表 sys_client.client_id 一致（沿用开发库初始化时请与 .env.development 相同）
VITE_APP_CLIENT_ID=e5cd7e4891bf95d1d19206ce24a7b32e

# Realtime features (optional)
VITE_APP_WEBSOCKET=false
VITE_APP_SSE=true

# External consoles (optional)
VITE_APP_MONITOR_ADMIN=
VITE_APP_SNAILJOB_ADMIN=
